#!/bin/sh

command -v claude >/dev/null 2>&1 || exit 0
command -v uvx >/dev/null 2>&1 || exit 0

register() {
  claude mcp remove "$1" --scope user >/dev/null 2>&1
  claude mcp add "$1" --scope user -- uvx "$2@latest" || echo "claude-mcp: failed to register $1 (skipped)" >&2
}

register aws-docs awslabs.aws-documentation-mcp-server
register aws-pricing awslabs.aws-pricing-mcp-server
register cloudwatch awslabs.cloudwatch-mcp-server

exit 0
