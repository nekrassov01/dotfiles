#!/bin/sh
#MISE description="Run textlint on the given paths"
# shellcheck disable=SC2154

# mise sets MISE_TASK_DIR; fall back to the script's own dir for direct execution
task_dir="${MISE_TASK_DIR:-$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)}"

# Run from the original working directory, not the mise config root
cd "${MISE_ORIGINAL_CWD:-$PWD}" || exit 1

# Use the bundled config unless the caller passes its own --config
case " $* " in
  *" --config "* | *" --config="*) : ;;
  *) set -- --config "$task_dir/.textlintrc.json" "$@" ;;
esac

# Use the bundled ignore list unless the caller passes its own --ignore-path
case " $* " in
  *" --ignore-path "* | *" --ignore-path="*) : ;;
  *) set -- --ignore-path "$task_dir/.textlintignore" "$@" ;;
esac

# No path given is left to textlint's native behavior
mise exec -- textlint "$@"
