#!/bin/sh
#MISE description="Run secretlint on the given paths"
# shellcheck disable=SC2154

# mise sets MISE_TASK_DIR; fall back to the script's own dir for direct execution
task_dir="${MISE_TASK_DIR:-$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)}"

# Run from the original working directory, not the mise config root
cd "${MISE_ORIGINAL_CWD:-$PWD}" || exit 1

# Use the bundled config unless the caller passes its own --secretlintrc
case " $* " in
  *" --secretlintrc "* | *" --secretlintrc="*) : ;;
  *) set -- --secretlintrc "$task_dir/.secretlintrc.json" "$@" ;;
esac

# Paths are literal (--no-glob); no path given is left to secretlint's native behavior
mise exec -- secretlint --no-glob "$@"
